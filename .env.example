# --- Supabase ---------------------------------------------------------------
# Project URL + anon (publishable) key power the browser & server SSR clients.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key: SERVER ONLY. Bypasses RLS. Used by seed script + admin client.
# Never expose this to the browser / never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The single owner (Peter). Every seeded row is stamped with this uuid.
# Get it from Supabase Auth after creating the owner user (see README deploy runbook).
OWNER_ID=00000000-0000-0000-0000-000000000000

# --- AI ---------------------------------------------------------------------
# Anthropic key lives server-side only (used by /api/ai/suggest route handler).
ANTHROPIC_API_KEY=sk-ant-...

# --- Cron (optional, future ingestion) --------------------------------------
CRON_SECRET=generate-a-long-random-string
