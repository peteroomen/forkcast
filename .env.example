# --- Supabase ---------------------------------------------------------------
# Forkcast shares the `personal-apps` project (ref ynsywxqgtsubzhibdjdz) and
# lives in the `forkcast` Postgres schema. The migration + seed are already
# applied to that project; you only need these values in Vercel to go live.
NEXT_PUBLIC_SUPABASE_URL=https://ynsywxqgtsubzhibdjdz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Service-role key: SERVER ONLY. Bypasses RLS. Only needed if you re-run the
# seed script locally. Never expose to the browser / never prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The single owner (Peter's auth-user uuid in the personal-apps project).
OWNER_ID=4abcea11-b313-4397-bc8e-c92dc020d731

# --- AI ---------------------------------------------------------------------
# Anthropic key lives server-side only (used by /api/ai/suggest route handler).
ANTHROPIC_API_KEY=sk-ant-...

# --- Cron (optional, future ingestion) --------------------------------------
CRON_SECRET=generate-a-long-random-string
